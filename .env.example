# HX Design Engine — Environment Configuration
# ================================================
# Copy to .env and fill in real values.

# Anthropic API Key (Claude Sonnet 4.6 for AI review)
HX_ANTHROPIC_API_KEY=

# Redis (session state)
HX_REDIS_URL=redis://localhost:6379/0

# Server
HX_HOST=0.0.0.0
HX_PORT=8100
HX_DEBUG=false

# MongoDB (optional — fouling factor cache)
HX_MONGODB_URI=mongodb://arken_app:arken_app_password@localhost:27017/arken_process_db?authSource=admin
HX_MONGODB_DB_NAME=arken_process_db

# Logging
HX_LOG_LEVEL=INFO
